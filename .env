# Environment Configuration (local/production)
# Set to 'production' for server deployment, 'local' for local dev.
ENV=local

# Database Configuration (for 'local', use host.docker.internal to reach host DB)
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=aoe_scoreboard

# Data Storage
DATA_DIR=/data
